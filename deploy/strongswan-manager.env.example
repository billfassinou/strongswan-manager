# SPDX-License-Identifier: AGPL-3.0-or-later
#
# Modèle de configuration. Le VRAI fichier — /etc/strongswan-manager/strongswan-manager.env —
# est généré à l'installation avec des secrets aléatoires, et n'est jamais réécrit ensuite.
# Ce modèle sert de référence pour les variables disponibles.
#
# Référence complète : https://billfassinou.github.io/strongswan-manager/docs/#/A2-configuration

# --- Obligatoire -------------------------------------------------------------

DATABASE_URL=postgres://swan:MOTDEPASSE@127.0.0.1:5432/swan?sslmode=disable

# Le serveur REFUSE de démarrer si ces deux valeurs sont laissées à leur défaut de
# développement (qui est public). Générez-les : openssl rand -hex 32
JWT_SECRET=
# ⚠️ SECRETS_KEY chiffre les secrets, les clés privées de la PKI et le certificat TLS.
#    Fixez-la AVANT le premier démarrage : elle ne peut plus être changée ensuite, sous
#    peine de rendre la base définitivement illisible. Sauvegardez ce fichier AVEC la base.
SECRETS_KEY=

# --- Comptes -----------------------------------------------------------------

# Mot de passe initial des 4 comptes (admin, operator, auditor, viewer). Il n'est utilisé
# qu'au tout premier démarrage, sur une base vide ; la console impose ensuite de le changer.
SEED_ADMIN_PASSWORD=

# --- Écouteurs ---------------------------------------------------------------

HTTP_ADDR=:7926
# Écouteur en clair : sert UNIQUEMENT /crl.der et /healthz, redirige le reste en 308.
HTTP_REDIRECT_ADDR=:7927

# --- Passerelles StrongSwan --------------------------------------------------

# Vide = MODE DÉMO : la console fonctionne, mais les tunnels sont SIMULÉS — aucun trafic
# n'est réellement chiffré. À renseigner pour piloter de vraies passerelles.
#   VICI_ENDPOINTS=local=unix:/var/run/charon.vici
#   VICI_ENDPOINTS=gw-paris=tcp:10.0.0.5:4502,gw-lyon=tcp:10.0.1.5:4502
VICI_ENDPOINTS=
POLL_INTERVAL=3s

# --- TLS ---------------------------------------------------------------------

# Par défaut, un certificat est auto-généré (signé par la CA interne) et persisté en base.
# Déclarez ici tous les noms/IP par lesquels la console est jointe, sinon le navigateur
# signalera une incohérence de nom en plus de l'avertissement d'autorité inconnue.
TLS_SANS=localhost,127.0.0.1,::1

# Votre propre certificat (PKI d'entreprise) :
# TLS_CERT=/etc/ssl/certs/console.pem
# TLS_KEY=/etc/ssl/private/console.key

# Certificat reconnu par les navigateurs. Exige un domaine public ET le port 80 joignable
# depuis Internet, redirigé vers HTTP_REDIRECT_ADDR (7927).
# ACME_DOMAIN=vpn.mondomaine.fr
# ACME_EMAIL=admin@mondomaine.fr
ACME_CACHE=/var/lib/strongswan-manager/acme

# Derrière un reverse proxy qui termine déjà le TLS :
# TLS_ENABLED=false

# --- CRL ---------------------------------------------------------------------

# Point de distribution de CRL inscrit dans les certificats émis. EN HTTP, sur l'écouteur
# clair : c'est charon qui le lit, et il ne ferait pas confiance à notre CA interne
# (RFC 5280 — il lui faudrait la CRL qu'il est justement en train de récupérer).
# À fixer AVANT d'émettre des certificats : ceux déjà émis embarquent l'URL telle quelle.
CRL_URL=http://192.0.2.10:7927/crl.der
CRL_VALIDITY=24h

# --- Divers ------------------------------------------------------------------

CORS_ORIGINS=*
JWT_TTL=1h

# Autorise le démarrage avec les secrets de développement. RÉSERVÉ AU LAB.
# ALLOW_INSECURE_DEFAULTS=true
